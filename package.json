{
  "name": "Asset_Management_Application-1781454148510",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@sap/cds-dk": "^9.9.2",
    "@sap/eslint-plugin-cds": "^4",
    "eslint": "^10"
  },
  "scripts": {
    "start": "cds-serve",
    "lint": "cds lint",
    "test": "cds test",
    "compile:check": "cds compile srv --to csn > /dev/null",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "quality": "npm run lint && npm test && npm run compile:check && npm run security:audit"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa",
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        }
      },
      "html5-repo": true,
      "destinations": true,
      "workzone": true
    }
  }
}
