{
  "welcomeFile": "/asset-ui/index.html",
  "authenticationMethod": "route",
  "logout": {
    "logoutEndpoint": "/logout",
    "logoutPage": "/asset-ui/logout.html"
  },
  "routes": [
    {
      "source": "^/asset-ui/logout\\.html$",
      "target": "logout.html",
      "localDir": "resources/asset-ui",
      "authenticationType": "none",
      "cacheControl": "no-cache, no-store, must-revalidate"
    },
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "source": "^/asset-ui/(.*)$",
      "target": "$1",
      "localDir": "resources/asset-ui",
      "authenticationType": "xsuaa"
    }
  ]
}
